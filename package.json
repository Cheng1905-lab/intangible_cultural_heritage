{
    "name": "feiyi-gongfang",
    "version": "1.0.0",
    "description": "非遗工坊 - 传统文化学习与体验平台",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "author": "非遗工坊",
    "license": "MIT",
    "devDependencies": {
        "electron": "^28.1.0",
        "electron-builder": "^24.13.3"
    },
    "build": {
        "appId": "com.feiyi.gongfang",
        "productName": "非遗工坊",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!node_modules"
        ],
        "win": {
            "target": "nsis",
            "icon": "images/icon-512.png"
        },
        "mac": {
            "target": "dmg",
            "icon": "images/icon-512.png"
        },
        "linux": {
            "target": "deb",
            "icon": "images/icon-512.png"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        }
    }
}
